# ─── CLT Assessment Platform — Environment Variables ───────────────────────
# Copy this file to .env.local for local development.
# Never commit real credentials to source control.
#
# See DEPLOYMENT.md for step-by-step setup instructions.
# See ARCHITECTURE.md §11 for the full variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres, ca-central-1) ───────────────────────────────
# Use the "Session mode" pooler URL from:
#   Supabase → Project Settings → Database → Connection pooling
# Format: postgresql://postgres.[ref]:[password]@aws-0-ca-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.YOURREF:PASSWORD@aws-0-ca-central-1.pooler.supabase.com:5432/postgres

# ── Authentication (next-auth v5) ────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
# next-auth v5 accepts AUTH_SECRET; NEXTAUTH_SECRET is a supported alias.
AUTH_SECRET=replace-with-32-byte-random-secret

# The canonical public URL of the deployed app (no trailing slash).
# Locally this is http://localhost:3000
AUTH_URL=http://localhost:3000

# ── Anthropic API (essay grading + translation) ──────────────────────────────
# Create a key at https://console.anthropic.com/
# Model used: claude-haiku-4-5 (see ARCHITECTURE.md §7 for cost breakdown)
#   • Essay grading:  ~$0.003 / essay
#   • Report translation: ~$0.004 / full report (zh-Hans, on-demand)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Email (Resend — magic-link auth for staff, optional) ─────────────────────
# Create a key at https://resend.com/ after verifying your sending domain.
# Only required if staff use magic-link sign-in instead of password auth.
RESEND_API_KEY=re_...

# ── Supabase Storage (audio assets — Phase 2 / T-060 only) ───────────────────
# Leave blank during Phase 1. Required when the audio pipeline is implemented.
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── TTS audio generation (one-time offline script only — Phase 2 / T-060) ────
# Used by scripts/generate-audio.ts to pre-generate listening passages.
# NOT used at runtime. Leave blank until audio pipeline is implemented.
OPENAI_API_KEY=sk-...
